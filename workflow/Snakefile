# --- URL / accession / path detection ---
def is_url(value: str) -> bool:
    """Check if value is a URL"""
    return isinstance(value, str) and (
        value.startswith(('http://', 'https://', 'ftp://', 'www.'))
    )

def is_sra_accession(value: str) -> bool:
    """Check if value is an SRA/ENA accession"""
    if not isinstance(value, str):
        return False
    # Match SRR/ERR/DRR followed by numbers
    return bool(re.match(r'^[SED]RR\d+$', value))

def is_ncbi_assembly_accession(value: str) -> bool:
    """Check if value is an NCBI assembly accession (GenBank or RefSeq)"""
    if not isinstance(value, str):
        return False
    import re
    # Match GCA_XXXXXXXXX.X or GCF_XXXXXXXXX.X
    return bool(re.match(r'^GC[AF]_\d{9}\.\d+$', value))

def is_existing_path(value: str) -> bool:
    """Check if value is an existing local path"""
    if not isinstance(value, str) or is_url(value) or is_sra_accession(value):
        return False
    return Path(value).exists()

def extract_filename_from_url(url: str) -> str:
    """Extract filename from URL"""
    parsed = urlparse(url)
    filename = Path(unquote(parsed.path)).name
    return filename if filename else "downloaded_file"

# --- Config value coercion ---
def _as_bool(x, default=False):
    """Convert various true/false representations to boolean"""
    if isinstance(x, bool): 
        return x
    if x is None: 
        return default
    s = str(x).strip().lower()
    return s in {"1", "true", "t", "yes", "y", "on"}

# --- Read-type normalization ---
def normalize_read_type(read_type):
    """
    Normalize read type to standard categories.
    Returns one of: 'hifi', 'ont', '10x', 'illumina', or original if unrecognized.
    """
    if not read_type or read_type == "None":
        return None
    
    read_type_lower = str(read_type).lower().replace("_", "").replace("-", "")
    
    # HiFi reads
    if any(term in read_type_lower for term in ["hifi", "pacbiohifi", "pbhifi", "ccs", "pacbio"]):
        return "hifi"
    
    # ONT reads
    if any(term in read_type_lower for term in ["ont", "nanopore", "oxfordnanopore", "minion", "promethion"]):
        return "ont"
    
    # 10x/linked reads (check before general illumina)
    if any(term in read_type_lower for term in ["10x", "tenx", "linkedreads", "linked"]):
        return "10x"
    
    # Illumina reads
    if any(term in read_type_lower for term in ["illumina", "shortreads", "pairedend", "pe", "sr"]):
        return "illumina"
    
    # Hi-C (special case paired-end)
    if any(term in read_type_lower for term in ["hic", "hi-c", "hic", "arima", "omnic", "omni-c"]):
        return "hic"
    
    # If we can't determine, return original lowercased
    return read_type.lower()

# --- Read-type predicates ---
def _is_long(rt):
    """Check if read type is long read (works with both raw and normalized types)"""
    rt_norm = normalize_read_type(rt)
    return rt_norm in {"hifi", "ont"}

def _is_short(rt):
    """Check if read type is short/paired-end read (works with both raw and normalized types)"""
    rt_norm = normalize_read_type(rt)
    return rt_norm in {"illumina", "10x"}

def _is_pe(rt):   
    """Check if read type produces paired-end files"""
    rt_norm = normalize_read_type(rt)
    return rt_norm in {"illumina", "10x", "hic"}

def _is_10x(rt):
    """Check if read type is 10x linked reads"""
    rt_norm = normalize_read_type(rt)
    return rt_norm == "10x"

def _is_hic(rt):
    """Check if read type is 10x linked reads"""
    rt_norm = normalize_read_type(rt)
    return rt_norm == "hic"

# --- Read-path utilities ---
_READ_EXTS = (".fastq.gz", ".fq.gz", ".fastq", ".fq", ".gz")
# Separator for BAM file names
_SEP = "_"
# Remove trailing _R1/_R2 or _1/_2 from basename
_PAIR_TOK_RE = re.compile(r"([._-])?(R?[12])$", re.IGNORECASE)

def _strip_ext(p):
    """Remove common read file extensions"""
    bn = os.path.basename(p)
    for ext in _READ_EXTS:
        if bn.endswith(ext): 
            return bn[:-len(ext)]
    return os.path.splitext(bn)[0]

def _strip_pair_token(bn): 
    """Remove pair indicators from basename"""
    return _PAIR_TOK_RE.sub("", bn)

# --- Read basename extraction ---
def get_read_basename(filepath):
    """Extract base name from read file path"""
    if not filepath or filepath == "None":
        return "unknown"
    
    basename = os.path.basename(filepath)
    # Remove extensions (.fq, .fastq, .fq.gz, .fastq.gz)
    basename = basename.replace('.fastq.gz', '').replace('.fq.gz', '')
    basename = basename.replace('.fastq', '').replace('.fq', '')
    return basename


# -------------------------------------------------------------------------------
# DATA TABLE HANDLING
# -------------------------------------------------------------------------------

def download_data_table(url: str, output_dir: Path) -> Path:
    """Download data table from URL with special handling for Google Sheets"""
    
    if IS_MAIN: print(f"[GAME] DATA_TABLE is a URL: {url}")
    # Special handling for Google Sheets
    if 'docs.google.com/spreadsheets' in url:
        match = re.search(r'/d/([a-zA-Z0-9-_]+)', url)
        if match:
            sheet_id = match.group(1)
            # Export as CSV
            url = f'https://docs.google.com/spreadsheets/d/{sheet_id}/export?format=csv'
            if IS_MAIN: print(f"[GAME] Detected Google Sheets, converting to export URL")
            filename = f"data_table_{sheet_id}.csv"
        else:
            raise ValueError("Could not extract spreadsheet ID from Google Sheets URL")
    else:
        # Try to get filename from URL
        parsed = urllib.parse.urlparse(url)
        filename = Path(parsed.path).name if parsed.path else "downloaded_data_table.csv"
        
        # Ensure proper extension
        valid_exts = ['.csv', '.tsv', '.txt', '.xlsx', '.xls']
        if not any(filename.endswith(ext) for ext in valid_exts):
            filename += '.csv'
    
    output_path = output_dir / filename
    
    # Check if already downloaded
    if output_path.exists():
        if IS_MAIN: print(f"[GAME] Using cached data table: {output_path}")
        return output_path
    
    # Download the file
    if IS_MAIN: print(f"[GAME] Downloading data table...")
    try:
        urllib.request.urlretrieve(url, output_path)
        if IS_MAIN: print(f"[GAME] Data table downloaded to: {output_path}")
    except (URLError, HTTPError) as e:
        raise ValueError(f"❌ Failed to download data table from {url}: {e}")
    
    return output_path

