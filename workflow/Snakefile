if _temp_dir_raw in ("", "default"):
    TEMP_DIR = FALLBACK_TMP
    TEMP_DIR_CANDIDATES = [FALLBACK_TMP]
    if IS_MAIN: print(f"[GAME] TEMP_DIR -> {TEMP_DIR}")
elif _temp_dir_raw == "auto":
    # Try to detect from profile's apptainer-args
    detected_paths = _parse_fast_paths_from_profiles()
    if detected_paths:
        TEMP_DIR = detected_paths[0]  # Primary choice
        TEMP_DIR_CANDIDATES = detected_paths + [FALLBACK_TMP]  # All options including fallback
        if IS_MAIN: print(f"[GAME] TEMP_DIR -> {TEMP_DIR} (auto, with {len(detected_paths)} fast option(s))")
        if IS_MAIN: print(f"[GAME] Fallback chain: {' -> '.join(TEMP_DIR_CANDIDATES)}")
    else:
        TEMP_DIR = FALLBACK_TMP
        TEMP_DIR_CANDIDATES = [FALLBACK_TMP]
        if IS_MAIN: print(f"[GAME] TEMP_DIR -> {TEMP_DIR} (auto, no fast path detected in profiles)")
else:
    # User-specified path - also add /tmp subdirectory
    user_path = str(config.get("TEMP_DIR", "")).strip()
    if not user_path.endswith("/tmp"):
        TEMP_DIR = os.path.join(user_path, "tmp")
    else:
        TEMP_DIR = user_path
    TEMP_DIR_CANDIDATES = [TEMP_DIR, FALLBACK_TMP]
    if IS_MAIN: print(f"[GAME] TEMP_DIR -> {TEMP_DIR}")
# --- Parse FAST_TEMP_DIR config ---
_fast_temp_raw = str(config.get("FAST_TEMP_DIR", "")).strip().lower()

if _fast_temp_raw in ("", "default"):
    FAST_TEMP_DIR = TEMP_DIR  # Same as TEMP_DIR by default
    # Show hints about better options
    ram_options = _detect_ramfs_mounts()
    if ram_options:
        if IS_MAIN: print(f"[GAME] FAST_TEMP_DIR -> {FAST_TEMP_DIR}")
        if IS_MAIN: print(f"[GAME] ⚡ RAM-mounted filesystems detected - consider setting FAST_TEMP_DIR for faster I/O:")
        for mnt, typ, free_gb in ram_options:
            if free_gb is not None:
                if IS_MAIN: print(f"       - {mnt} [{typ}] ~{free_gb:.1f} GiB free")
            else:
                if IS_MAIN: print(f"       - {mnt} [{typ}]")
    else:
        if IS_MAIN: print(f"[GAME] FAST_TEMP_DIR -> {FAST_TEMP_DIR}")
else:
    # User-specified path - also add /tmp subdirectory
    user_fast_path = str(config.get("FAST_TEMP_DIR", "")).strip()
    if not user_fast_path.endswith("/tmp"):
        FAST_TEMP_DIR = os.path.join(user_fast_path, "tmp")
    else:
        FAST_TEMP_DIR = user_fast_path
    if IS_MAIN: print(f"[GAME] FAST_TEMP_DIR -> {FAST_TEMP_DIR}")
# Build the candidates list as a colon-separated string for shell
TEMP_CANDIDATES_STR = ":".join(TEMP_DIR_CANDIDATES)

# Export for every shell step (works inside Apptainer too)
# Include a helper function for runtime space checking with multiple fallbacks
shell.prefix(
    f"set -euo pipefail; "
    f"export TMPDIR='{TEMP_DIR}'; "
    f"export GAME_TMP='{TEMP_DIR}'; "
    f"export GAME_FAST_TMP='{FAST_TEMP_DIR}'; "
    f"export GAME_FALLBACK_TMP='{FALLBACK_TMP}'; "
    f"export GAME_TMP_CANDIDATES='{TEMP_CANDIDATES_STR}'; "
    # Function to get work dir with space check and multiple fallbacks
    """
game_get_workdir() {{
    local REQUIRED_GB="${{1:-100}}"
    local PENALTY_PER_JOB=50  # Subtract 50GB per existing GAME temp folder
    local FALLBACK="${{GAME_FALLBACK_TMP:-/tmp}}"
    
    echo "[GAME] Temp directory selection:" >&2
    echo "[GAME]   Required: ${{REQUIRED_GB}} GB (with ${{PENALTY_PER_JOB}} GB penalty per existing GAME job)" >&2
    
    # Parse candidates (colon-separated)
    IFS=':' read -ra CANDIDATES <<< "${{GAME_TMP_CANDIDATES:-$FALLBACK}}"
    
    for CANDIDATE in "${{CANDIDATES[@]}}"; do
        echo "[GAME]   Checking: $CANDIDATE" >&2
        
        # Check if directory exists or can be created
        if ! mkdir -p "$CANDIDATE" 2>/dev/null; then
            echo "[GAME]     Cannot create/access directory" >&2
            continue
        fi
        
        # Get available space
        AVAIL_KB=$(df -k "$CANDIDATE" 2>/dev/null | awk 'NR==2 {{print $4}}' || echo "0")
        AVAIL_GB=$((AVAIL_KB / 1024 / 1024))
        
        # Count existing GAME temp folders directly in this tmp directory
        EXISTING_JOBS=0
        if [ -d "$CANDIDATE" ]; then
            EXISTING_JOBS=$(find "$CANDIDATE" -maxdepth 1 -type d -name "GAME_*" 2>/dev/null | wc -l || echo "0")
        fi
        
        # Calculate adjusted available space
        PENALTY=$((EXISTING_JOBS * PENALTY_PER_JOB))
        ADJUSTED_GB=$((AVAIL_GB - PENALTY))
        
        echo "[GAME]     Raw available: ${{AVAIL_GB}} GB" >&2
        if [ "$EXISTING_JOBS" -gt 0 ]; then
            echo "[GAME]     Existing GAME jobs: $EXISTING_JOBS (penalty: -${{PENALTY}} GB)" >&2
            echo "[GAME]     Adjusted available: ${{ADJUSTED_GB}} GB" >&2
        fi
        
        # Check if adjusted space is sufficient
        if [ "${{ADJUSTED_GB:-0}}" -ge "$REQUIRED_GB" ] 2>/dev/null; then
            echo "[GAME] Using: $CANDIDATE (${{ADJUSTED_GB}} GB effective, ${{AVAIL_GB}} GB raw)" >&2
            echo "$CANDIDATE"
            return 0
        fi
        
        echo "[GAME]     ❌ Insufficient space (${{ADJUSTED_GB}} GB < ${{REQUIRED_GB}} GB required)" >&2
    done
    
    # All candidates exhausted, use fallback anyway with warning
    mkdir -p "$FALLBACK" 2>/dev/null || true
    FALLBACK_KB=$(df -k "$FALLBACK" 2>/dev/null | awk 'NR==2 {{print $4}}' || echo "0")
    FALLBACK_GB=$((FALLBACK_KB / 1024 / 1024))
    echo "[GAME] ⚠️  All fast options exhausted, using fallback: $FALLBACK (${{FALLBACK_GB}} GB free)" >&2
    echo "$FALLBACK"
}}
"""
)


