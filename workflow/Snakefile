# -------------------------------------------------------------------------------
# SAMPLES CONFIG LOADING
# -------------------------------------------------------------------------------

# --- YAML processing ---
def process_yaml_for_downloads(yaml_data: dict, out_folder: Path) -> tuple:
    """
    Process YAML to detect downloads needed and update paths.
    DEDUPLICATES reads by storing them at a centralized reads/ folder (sample-centric, not species-centric).
    This allows the same reads to be used with multiple assemblies without re-downloading.
    Returns: (updated_yaml, download_manifest)
    """
    updated_yaml = copy.deepcopy(yaml_data)
    download_manifest = []
    
    # Track what we've already queued to avoid duplicates
    # Key format varies by type - reads are keyed by sample_id only (species-independent)
    queued_downloads = {}
    
    for sp_name, sp_data in yaml_data.get("sp_name", {}).items():
        if not sp_data or "asm_id" not in sp_data:
            continue
            
        for asm_id, asm_data in sp_data["asm_id"].items():
            if not asm_data:
                continue
            
            # -----------------------------------------------------------------
            # Process assembly file (species-specific - stays in species folder)
            # -----------------------------------------------------------------
            asm_file = asm_data.get("asm_file")
            if asm_file and not is_existing_path(asm_file):
                if is_url(asm_file):
                    filename = extract_filename_from_url(asm_file)
                    # Assemblies go to species/assemblies/ folder (species-specific)
                    local_path = out_folder / "downloaded_data" / "assemblies" / sp_name / filename
                    
                    dedup_key = ("assembly", asm_file, sp_name)
                    if dedup_key not in queued_downloads:
                        download_manifest.append({
                            "type": "assembly",
                            "source": asm_file,
                            "destination": str(local_path),
                            "method": "curl",
                            "species": sp_name,
                            "assembly": asm_id
                        })
                        queued_downloads[dedup_key] = str(local_path)
                        if IS_MAIN: print(f"[GAME] Assembly download queued: {asm_file}")
                    else:
                        local_path = Path(queued_downloads[dedup_key])
                    
                    updated_yaml["sp_name"][sp_name]["asm_id"][asm_id]["asm_file"] = str(local_path)
            
                elif is_ncbi_assembly_accession(asm_file):
                    filename = f"{asm_file}_genomic.fna.gz"
                    # Assemblies go to species/assemblies/ folder (species-specific)
                    local_path = out_folder / "downloaded_data" / "assemblies" / sp_name / filename
                    
                    dedup_key = ("assembly", asm_file, sp_name)
                    if dedup_key not in queued_downloads:
                        download_manifest.append({
                            "type": "assembly",
                            "source": asm_file,
                            "destination": str(local_path),
                            "method": "ncbi_assembly",
                            "species": sp_name,
                            "assembly": asm_id
                        })
                        queued_downloads[dedup_key] = str(local_path)
                        if IS_MAIN: print(f"[GAME] Assembly download queued: {asm_file}")
                    else:
                        local_path = Path(queued_downloads[dedup_key])
                    
                    updated_yaml["sp_name"][sp_name]["asm_id"][asm_id]["asm_file"] = str(local_path)

            # -----------------------------------------------------------------
            # Process sample reads - CENTRALIZED at reads/sample_id/read_type
            # Species-independent! Same reads can be used with multiple assemblies
            # -----------------------------------------------------------------
            if "sample_id" not in asm_data:
                continue
                
            for sample_id, sample_data in asm_data["sample_id"].items():
                if not sample_data or "read_type" not in sample_data:
                    continue
                
                for read_type, rt_data in sample_data["read_type"].items():
                    if read_type == "None" or not rt_data:
                        continue
                    
                    read_files = rt_data.get("read_files", {})
                    if not read_files:
                        continue
                    
                    # Determine if paired-end
                    is_paired = read_type.lower() in ["illumina", "10x"]
                    
                    for path_key, path_value in read_files.items():
                        if not path_value or path_value == "None":
                            continue
                        
                        # Handle existing comma-separated paired reads
                        if isinstance(path_value, str) and "," in path_value:
                            paths = [p.strip() for p in path_value.split(",")]
                        elif isinstance(path_value, list):
                            paths = path_value
                        else:
                            paths = [path_value]
                        
                        new_paths = []
                        
                        for path in paths:
                            if is_existing_path(path):
                                new_paths.append(path)
                                continue
                            
                            # -------------------------------------------------------
                            # CENTRALIZED PATH: reads/sample_id/read_type/
                            # Species-independent - same reads work with any assembly!
                            # -------------------------------------------------------
                            base_dir = out_folder / "downloaded_data" / "reads" / sample_id / read_type
                            
                            if is_url(path):
                                filename = extract_filename_from_url(path)
                                local_path = base_dir / filename
                                
                                # Dedup key: sample + read_type + URL (no species!)
                                dedup_key = ("reads_url", path, sample_id, read_type)
                                if dedup_key not in queued_downloads:
                                    download_manifest.append({
                                        "type": "reads",
                                        "source": path,
                                        "destination": str(local_path),
                                        "method": "curl",
                                        "sample": sample_id,
                                        "read_type": read_type
                                    })
                                    queued_downloads[dedup_key] = str(local_path)
                                    if IS_MAIN: print(f"[GAME] Reads download queued: {path}")
                                else:
                                    local_path = Path(queued_downloads[dedup_key])
                                
                                new_paths.append(str(local_path))
                                
                            elif is_sra_accession(path):
                                # Dedup key: sample + read_type + SRA accession (no species!)
                                dedup_key = ("reads_sra", path, sample_id, read_type)
                                
                                if is_paired:
                                    # Paired-end reads
                                    local_r1 = base_dir / f"{path}_1.fastq.gz"
                                    local_r2 = base_dir / f"{path}_2.fastq.gz"
                                    
                                    if dedup_key not in queued_downloads:
                                        download_manifest.append({
                                            "type": "reads",
                                            "source": path,
                                            "destination": str(base_dir / path),  # Base path for enaDataGet
                                            "method": "enaDataGet",
                                            "paired": True,
                                            "sample": sample_id,
                                            "read_type": read_type
                                        })
                                        queued_downloads[dedup_key] = (str(local_r1), str(local_r2))
                                        if IS_MAIN: print(f"[GAME] SRA paired reads queued: {path}")
                                    else:
                                        local_r1, local_r2 = queued_downloads[dedup_key]
                                    
                                    new_paths.extend([str(local_r1), str(local_r2)])
                                else:
                                    # Single-end long reads
                                    local_path = base_dir / f"{path}.fastq.gz"
                                    
                                    if dedup_key not in queued_downloads:
                                        download_manifest.append({
                                            "type": "reads",
                                            "source": path,
                                            "destination": str(local_path),
                                            "method": "enaDataGet",
                                            "paired": False,
                                            "sample": sample_id,
                                            "read_type": read_type
                                        })
                                        queued_downloads[dedup_key] = str(local_path)
                                        if IS_MAIN: print(f"[GAME] SRA reads queued: {path}")
                                    else:
                                        local_path = Path(queued_downloads[dedup_key])
                                    
                                    new_paths.append(str(local_path))
                        
                        # Update YAML with new paths
                        if new_paths:
                            if len(new_paths) == 1:
                                updated_yaml["sp_name"][sp_name]["asm_id"][asm_id]["sample_id"][sample_id]["read_type"][read_type]["read_files"][path_key] = new_paths[0]
                            else:
                                # Paired reads - store as comma-separated string
                                updated_yaml["sp_name"][sp_name]["asm_id"][asm_id]["sample_id"][sample_id]["read_type"][read_type]["read_files"][path_key] = ", ".join(new_paths)
    
    # -----------------------------------------------------------------
    # Print deduplication summary
    # -----------------------------------------------------------------
    asm_downloads = len([k for k in queued_downloads if k[0] == "assembly"])
    reads_downloads = len([k for k in queued_downloads if k[0].startswith("reads")])
    
    # Count how many manifest entries we would have had without dedup
    total_asm_refs = sum(
        1 for sp_data in yaml_data.get("sp_name", {}).values()
        if sp_data and "asm_id" in sp_data
        for asm_data in sp_data["asm_id"].values()
        if asm_data and asm_data.get("asm_file") and not is_existing_path(asm_data.get("asm_file", ""))
    )
    
    if asm_downloads < total_asm_refs:
        if IS_MAIN: print(f"[GAME] Assembly deduplication: {total_asm_refs} references -> {asm_downloads} unique downloads")
    if reads_downloads > 0:
        if IS_MAIN: print(f"[GAME] Download manifest: {asm_downloads} assemblies, {reads_downloads} read sets (deduplicated)")
    return updated_yaml, download_manifest

# --- Loader ---
def load_samples_config():
    """Safely load the samples configuration with error handling"""
    
    # Check if YAML already exists and is recent
    if yaml_output.exists():
        yaml_mtime = yaml_output.stat().st_mtime
        csv_mtime = input_table.stat().st_mtime
        
        # If YAML is newer than CSV, just load it
        if yaml_mtime > csv_mtime:
            try:
                with yaml_output.open() as f:
                    config_data = yaml.safe_load(f)
                if config_data and "sp_name" in config_data:
                    return config_data
            except:
                pass  # Fall through to regeneration
    
    # Generate fresh YAML data table
    if IS_MAIN: print("(U ᵔﻌᵔ)っ  Generating YAML data table from input...")
    result = subprocess.run(
        ["nomnom",
         "-a", 
         str(scripts_dir / "GAME_table.attributes"),
         "-o", 
         str(yaml_output),
         "--discover-paths", 
         str(input_table)],
        capture_output=True, 
        text=True
    )
    if result.returncode != 0:
        print("(U ಥ ﻌ ಥ)  Error generating YAML configuration:")
        print(result.stdout if result.stdout else "")
        print(result.stderr if result.stderr else "")
        sys.exit(1)

    # Load the generated YAML data table
    with yaml_output.open() as f:
        config_data = yaml.safe_load(f)
    
    if not config_data or "sp_name" not in config_data:
        print(f"❌ Error: Invalid YAML structure in {yaml_output}")
        sys.exit(1)

    # Process for downloads
    if IS_MAIN: print("[GAME] Scanning for URLs and accessions...")
    updated_yaml, download_manifest = process_yaml_for_downloads(config_data, out_folder)
    
    if download_manifest:
        # Save download manifest
        manifest_path = out_folder / "download_manifest.json"
        with manifest_path.open('w') as f:
            json.dump(download_manifest, f, indent=2)
        if IS_MAIN: print(f"[GAME] Download manifest created: {manifest_path}")
        if IS_MAIN: print(f"[GAME] Total downloads queued: {len(download_manifest)}")
        # Save updated YAML
        with yaml_output.open('w') as f:
            yaml.dump(updated_yaml, f, default_flow_style=False, sort_keys=False)
        if IS_MAIN: print(f"[GAME] YAML updated with local paths")
        return updated_yaml
    else:
        if IS_MAIN: print("[GAME] No downloads needed - all data is local")
        return config_data

# --- Run the loader ---
if IS_MAIN: print(f"(∪≖ﻌ≖∪)  NomNom is handling the data table...")

samples_config = load_samples_config()


# -------------------------------------------------------------------------------
# HELPERS
# -------------------------------------------------------------------------------

# --- Sample data extraction ---
def _get_sample_node(species, assembly, sample_id, read_type_key=None):
    """Extract sample data from config"""
    try:
        node = samples_config["sp_name"][species]["asm_id"][assembly]["sample_id"][sample_id]
        
        if not node.get("read_type") or node["read_type"] == {"None": {}}:
            return None, False, {}
        
        # Simplified - just get reads, no trim_qc logic
        if read_type_key:
            target_norm = normalize_read_type(read_type_key)
            actual_key = None
            for yaml_key in node["read_type"]:
                if normalize_read_type(yaml_key) == target_norm:
                    actual_key = yaml_key
                    break
            
            if not actual_key:
                return None, False, {}
            
            sub = node["read_type"][actual_key]
            reads = sub.get("read_files", {}) or {}
            reads = {k: v for k, v in reads.items() 
                    if v not in [None, "None"] and k.startswith("Path")}
            
            # Determine trim flag based on read type
            is_pe = target_norm in ["illumina", "10x"]
            is_hifi = target_norm == "hifi"

            if is_pe:
                trim = _as_bool(config.get("TRIM_PE", True))
            elif is_hifi:
                trim = _as_bool(config.get("FILTER_HIFI", False))
            else:
                trim = False
            
            return target_norm, trim, reads
        
        # Otherwise return first (for backward compatibility)
        rt = next(iter(node["read_type"]))
        if rt == "None" or rt is None:
            return None, False, {}
        
        sub = node["read_type"][rt]
        reads = sub.get("read_files", {}) or {}
        reads = {k: v for k, v in reads.items() 
                if v not in [None, "None"] and k.startswith("Path")}
        
        rt_norm = normalize_read_type(rt)
        is_pe = rt_norm in ["illumina", "10x"]
        trim = _as_bool(config.get("TRIM_PE", True)) if is_pe else False
        
        return rt_norm, trim, reads
        
    except (KeyError, TypeError, AttributeError):
        return None, False, {}

def _normalize_pe(val):
    """Parse paired-end read paths from various formats"""
    # Handle list format
    if isinstance(val, list) and len(val) >= 2: 
        return str(val[0]).strip(), str(val[1]).strip()
    
    # Handle comma-separated string
    if isinstance(val, str) and "," in val:
        parts = [x.strip() for x in val.split(",", 1)]  # Split only on first comma
        if len(parts) >= 2: 
            return parts[0], parts[1]
    
    # Invalid format
    raise ValueError(f"Paired-end entry must have two reads, got: {val!r}")

def _enumerate_groups(rt, reads_dict):
    """Generate read groups with consistent numbering"""
    if not reads_dict:
        return
    
    # Sort by Path number if possible
    def sort_key(k):
        if k.startswith("Path"):
            try:
                return int(k[4:])  # Extract number from "Path1", "Path2", etc.
            except ValueError:
                pass
        return k
    
    for i, key in enumerate(sorted(reads_dict.keys(), key=sort_key), 1):
        val = reads_dict[key]
        
        if _is_long(rt):
            # Single/long read
            r = val if isinstance(val, str) else (val[0] if isinstance(val, list) else str(val))
            base = _strip_ext(r)
            yield {"idx": i, "rt": rt, "kind": "long", "r": r, "base": base}
        else:
            # Paired-end read
            try:
                r1, r2 = _normalize_pe(val)
                base = _strip_pair_token(_strip_ext(r1))
                yield {"idx": i, "rt": rt, "kind": "pe", "r1": r1, "r2": r2, "base": base}
            except ValueError as e:
                print(f"Warning: Skipping invalid PE entry for {key}: {e}")
                continue

# --- Output path generation ---
def _reads_outdir(sp, asm, sid):
    """Get reads output directory"""
    return os.path.join(config["OUT_FOLDER"], "GAME_results", sp, asm, "samples", str(sid), "reads")

def _reads_reportdir(sp, asm, sid):
    """Get reports output directory"""
    return os.path.join(_reads_outdir(sp, asm, sid), "reports")

def _outputs_for_group(sp, asm, sid, grp, trim):
    """Generate output filenames for a read group (sample-centric)"""
    data_base = os.path.join(config["OUT_FOLDER"], "GAME_results", "data")
    rt = grp["rt"]
    i  = grp["idx"]
    base = grp["base"]

    if grp["kind"] == "long":
        if rt == "hifi" and config.get("FILTER_HIFI", False):
            name = f"Path{i}_{base}_filtered.fq.gz"
            return [os.path.join(data_base, sid, rt, "processed", name)]
        elif rt == "ont" and config.get("CORRECT_ONT", False):
            name = f"Path{i}_{base}_corrected.fq.gz"
            return [os.path.join(data_base, sid, rt, "processed", name)]
        else:
            name = f"Path{i}_{base}.fq.gz"
            return [os.path.join(data_base, sid, rt, name)]
    else:
        if trim:
            subdir = os.path.join(data_base, sid, rt, "processed")
            r1 = os.path.join(subdir, f"Path{i}_{base}_R1_trimmed.fq.gz")
            r2 = os.path.join(subdir, f"Path{i}_{base}_R2_trimmed.fq.gz")
        else:
            subdir = os.path.join(data_base, sid, rt)
            r1 = os.path.join(subdir, f"Path{i}_{base}_R1.fq.gz")
            r2 = os.path.join(subdir, f"Path{i}_{base}_R2.fq.gz")
        return [r1, r2]

# --- Public interface ---
def sample_read_outputs(sp, asm, sid):
    """Get all expected output files for a sample (all read types)"""
    outs = []
    try:
        sample_data = samples_config["sp_name"][sp]["asm_id"][asm]["sample_id"][sid]
        if not sample_data.get("read_type"):
            return outs
        for rt_key in sample_data["read_type"]:
            if rt_key == "None" or rt_key is None:
                continue
            rt, trim, reads = _get_sample_node(sp, asm, sid, rt_key)
            if rt and reads:
                for grp in _enumerate_groups(rt, reads):
                    outs.extend(_outputs_for_group(sp, asm, sid, grp, trim))
    except (KeyError, TypeError, AttributeError):
        pass
    return outs

def sample_read_inputs(sp, asm, sid):
    """Get all input read files for a sample (all read types)"""
    ins = []
    
    try:
        sample_data = samples_config["sp_name"][sp]["asm_id"][asm]["sample_id"][sid]
        if not sample_data.get("read_type"):
            return ins
        
        # Process each read type for this sample
        for rt_key in sample_data["read_type"]:
            if rt_key == "None" or rt_key is None:
                continue
            
            rt, _, reads = _get_sample_node(sp, asm, sid, rt_key)
            
            if rt and reads:
                for grp in _enumerate_groups(rt, reads):
                    if grp["kind"] == "long": 
                        ins.append(grp["r"])
                    else: 
                        ins.extend([grp["r1"], grp["r2"]])
    except (KeyError, TypeError, AttributeError):
        pass
    
    return ins

def resource_key_for_sample(sp, asm, sid):
    rt, trim, reads = _get_sample_node(sp, asm, sid)
    
    # Check if this is HiFi with filtering
    if rt == "hifi" and config.get("FILTER_HIFI", False):
        return "trim_hifi"
    
    if not trim:
        # Check if any files need compression
        for grp in _enumerate_groups(rt, reads):
            if grp["kind"] == "long" and not grp["r"].endswith('.gz'):
                return "compress_reads"  # Needs compression
            elif grp["kind"] == "pe":
                if not grp["r1"].endswith('.gz') or not grp["r2"].endswith('.gz'):
                    return "compress_reads"  # Needs compression
        return "light_task"  # Only linking needed
    
    return "trim_long_reads" if _is_long(rt) else "trim_illumina_pe"

def all_samples_iter():
    """Iterate over all valid samples with read data"""
    for sp, sd in samples_config["sp_name"].items():
        if not sd or "asm_id" not in sd:
            continue
        for asm, ad in sd["asm_id"].items():
            if not ad or "sample_id" not in ad:
                continue
            for sid in ad["sample_id"]:
                # Skip None samples
                if sid == "None" or sid is None:
                    continue
                # Check if sample has ANY valid read data (any read type)
                sample_data = ad["sample_id"][sid]
                if sample_data.get("read_type"):
                    has_valid_reads = False
                    for rt_key in sample_data["read_type"]:
                        if rt_key != "None":
                            rt_norm = normalize_read_type(rt_key)
                            _, _, reads = _get_sample_node(sp, asm, sid, rt_key)
                            if reads:  # Only if there are actual read files
                                has_valid_reads = True
                                break
                    if has_valid_reads:
                        yield sp, asm, sid

# --- BED handling for masking ---
def get_sibling_bed_path(species, assembly):
    """
    Return the path to a sibling BED file located next to the assembly, if one
    exists. A sibling BED shares the assembly's base name (with .fa/.fasta/.fna
    and .gz/.bgz stripped) and has extension .bed.gz (preferred) or .bed.

    Examples:
        /data/genome.fa.gz   -> /data/genome.bed.gz   (preferred)
                             -> /data/genome.bed      (fallback)
        /data/genome.fasta   -> /data/genome.bed.gz / .bed

    note: this check runs at DAG-construction time. A BED dropped into the
    folder after the pipeline has started will NOT be picked up without
    re-running snakemake.

    Returns the path as a string if found, else None.
    """
    asm_path = get_assembly_path(species, assembly)
    if not asm_path:
        return None

    base = asm_path
    for ext in (".gz", ".bgz"):
        if base.endswith(ext):
            base = base[: -len(ext)]
            break
    for ext in (".fa", ".fasta", ".fna"):
        if base.endswith(ext):
            base = base[: -len(ext)]
            break

    for candidate in (base + ".bed.gz", base + ".bed"):
        if os.path.exists(candidate):
            return candidate

    return None

# -------------------------------------------------------------------------------
# COLLECTORS
# -------------------------------------------------------------------------------

# --- Assembly stats ---
def get_asm_stats_results():
    expected_files = []
    
    if not samples_config or "sp_name" not in samples_config:
        print("❌ Error: samples_config is invalid")
        return expected_files
    
    run_compl = _as_bool(config.get("RUN_COMPL", True))
    
    for species, species_data in samples_config["sp_name"].items():
        if not species_data or "asm_id" not in species_data:
            continue
            
        for assembly, assembly_data in species_data["asm_id"].items():
            if not assembly_data:
                continue
                
            base_path = os.path.join(out_folder, species, assembly, "assembly_stats")
            
            # gfastats always
            expected_files.append(
                os.path.join(base_path, "gfastats", "stats.txt")
            )
            
            # compleasm only if enabled
            if run_compl:
                expected_files.append(
                    os.path.join(base_path, "compleasm", "summary.txt")
                )
                expected_files.append(
                    os.path.join(base_path, "compleasm", "compleasm_results.tar.gz")
                )
            
            # report always (gfastats-only or gfastats+compleasm)
            expected_files.append(
                os.path.join(base_path, f"{assembly}_mini_report.md")
            )
    
    return expected_files

# --- Repeat masking ---
def get_repeat_masking_results():
    """Get expected output files from repeat masking analysis.

    Behavior is governed by the MASKING control-panel variable:
      - off/none/empty: no masking outputs
      - on: full RepeatMasker pipeline
      - auto: if a sibling BED exists next to the assembly, use it;
              otherwise extract masked regions from a softmasked assembly
    """
    expected_files = []

    mode = str(config.get("MASKING", "off")).strip().lower()

    if mode in ("", "off", "false", "no", "0", "none"):
        return expected_files

    for species, species_data in samples_config["sp_name"].items():
        for assembly, assembly_data in species_data["asm_id"].items():
            base_path = os.path.join(
                config["OUT_FOLDER"], "GAME_results", species, assembly, "masking"
            )

            if mode in ("on", "true", "yes", "1"):
                # Run full RepeatMasker
                expected_files.extend([
                    # Main masking outputs (compressed)
                    os.path.join(base_path, f"{assembly}.masked.fa.gz"),
                    os.path.join(base_path, f"{assembly}.fa.out.gz"),
                    os.path.join(base_path, f"{assembly}.fa.out.gff.gz"),
                    os.path.join(base_path, f"{assembly}.mask_from_rm.bed.gz"),
                    # Uncompressed files that remain
                    os.path.join(base_path, f"{assembly}.fa.align"),
                    os.path.join(base_path, f"{assembly}.fa.tbl"),
                    # Small landscape analysis outputs (uncompressed)
                    os.path.join(base_path, f"{assembly}.fa.align.divsum"),
                    os.path.join(base_path, f"{assembly}.fa.align.divsum.html"),
                    os.path.join(base_path, f"{assembly}.repeat_landscape.svg"),
                    os.path.join(base_path, f"{assembly}.repeat_landscape.tsv"),
                    # Large files (compressed)
                    os.path.join(base_path, f"{assembly}.fa.align_with_div.gz"),
                    # Library outputs (compressed)
                    os.path.join(base_path, "modeler", f"{assembly}-families.fa.gz"),
                    os.path.join(base_path, "modeler", f"{assembly}-families.stk"),
                    os.path.join(base_path, "libraries", f"{assembly}_combined.fa.gz"),
                    os.path.join(base_path, "libraries", f"{assembly}-rm.fa.gz"),
                ])

            elif mode == "auto":
                # Prefer sibling BED next to the assembly; fall back to extracting
                # softmasked regions from the FASTA.
                if get_sibling_bed_path(species, assembly) is not None:
                    expected_files.append(
                        os.path.join(base_path, f"{assembly}.mask_from_file.bed.gz")
                    )
                else:
                    expected_files.append(
                        os.path.join(base_path, f"{assembly}.mask_from_ref.bed.gz")
                    )

            else:
                # Unknown value — fail loudly rather than silently skipping
                raise ValueError(
                    f"[GAME] Invalid MASKING value: {config.get('MASKING')!r}. "
                    f"Expected one of: off, on, auto (or their aliases)."
                )

    return expected_files

# --- Read processing / QC ---
def get_read_processing_results():
    """
    Get all expected read processing outputs (SAMPLE-CENTRIC).
    Since reads are now processed once per sample (not per assembly),
    we deduplicate by sample_id.
    """
    outs = []
    seen_samples = set()  # Track (sample_id, read_type) to avoid duplicates
    
    for sp, asm, sid in all_samples_iter():
        try:
            sample_data = samples_config["sp_name"][sp]["asm_id"][asm]["sample_id"][sid]
            if not sample_data.get("read_type"):
                continue
            
            for rt_key in sample_data["read_type"]:
                if rt_key in ["None", None]:
                    continue
                
                rt_norm = normalize_read_type(rt_key)
                dedup_key = (sid, rt_norm)
                
                # Skip if we've already added outputs for this sample/read_type
                if dedup_key in seen_samples:
                    continue
                seen_samples.add(dedup_key)
                
                _, _, reads = _get_sample_node(sp, asm, sid, rt_key)
                if not reads:
                    continue
                
                # Base path for sample data (sample-centric)
                base_path = os.path.join(
                    config["OUT_FOLDER"], "GAME_results", "data", sid, rt_norm
                )
                
                for grp in _enumerate_groups(rt_norm, reads):
                    idx = grp["idx"]
                    base = grp["base"]
                    
                    if grp["kind"] == "long":
                        # Raw long reads (symlinked)
                        outs.append(os.path.join(
                            base_path, f"Path{idx}_{base}.fq.gz"
                        ))
                        
                        # NanoPlot for raw reads
                        outs.append(os.path.join(
                            base_path, "reports", f"Path{idx}_{base}_nanoplot"
                        ))
                        
                        # HiFi-specific outputs
                        if rt_norm == "hifi":
                            # ULI primer check
                            outs.append(os.path.join(
                                base_path, "reports", f"Path{idx}_{base}_uli_mqc.yaml"
                            ))
                            # Filtered reads if enabled
                            if config.get("FILTER_HIFI", False):
                                outs.append(os.path.join(
                                    base_path, "processed", f"Path{idx}_{base}_filtered.fq.gz"
                                ))
                        
                        # ONT correction if enabled
                        if rt_norm == "ont" and config.get("CORRECT_ONT", False):
                            outs.append(os.path.join(
                                base_path, "processed", f"Path{idx}_{base}_corrected.fq.gz"
                            ))
                            # NanoPlot for corrected reads
                            outs.append(os.path.join(
                                base_path, "reports", f"Path{idx}_{base}_corrected_nanoplot"
                            ))
                    
                    elif grp["kind"] == "pe":
                        if config.get("TRIM_PE", True):
                            # Trimmed PE reads
                            outs.append(os.path.join(
                                base_path, "processed", f"Path{idx}_{base}_R1_trimmed.fq.gz"
                            ))
                            outs.append(os.path.join(
                                base_path, "processed", f"Path{idx}_{base}_R2_trimmed.fq.gz"
                            ))
                            # Fastp reports
                            outs.append(os.path.join(
                                base_path, "reports", f"Path{idx}_{base}_fastp.json"
                            ))
                        else:
                            # Raw PE reads (symlinked)
                            outs.append(os.path.join(
                                base_path, f"Path{idx}_{base}_R1.fq.gz"
                            ))
                            outs.append(os.path.join(
                                base_path, f"Path{idx}_{base}_R2.fq.gz"
                            ))
                
                # Sample-level MultiQC report (one per sample, at sample level)
                # Only add once per sample (not per read_type)
                multiqc_path = os.path.join(
                    config["OUT_FOLDER"], "GAME_results", "data", sid,
                    "multiqc_report.html"
                )
                if multiqc_path not in outs:
                    outs.append(multiqc_path)
        
        except (KeyError, TypeError, AttributeError):
            pass
    
    return outs

# --- Mapping & dedup ---
def get_mapping_results():
    outs = []
    seen = set()  # track (species, assembly) for aggregate reports

    for sp, asm, sid in all_samples_iter():
        # Get sample data ONCE at the beginning
        try:
            sample_data = samples_config["sp_name"][sp]["asm_id"][asm]["sample_id"][sid]
            if not sample_data.get("read_type"):
                continue
            
            # Count valid read types
            valid_techs = [rt for rt in sample_data["read_type"] 
                          if rt != "None" and rt is not None]
            tech_count = len(valid_techs)
            
            bdir = os.path.join(config["OUT_FOLDER"], "GAME_results", sp, asm, "samples", sid, "BAMs")
            
            # Process each read type
            for rt_key in valid_techs:
                rt_norm = normalize_read_type(rt_key)
                rt, trim, reads = _get_sample_node(sp, asm, sid, rt_key)
                
                if not rt or not reads:
                    continue
                
                # per-group outputs
                for grp in _enumerate_groups(rt, reads):
                    idx = grp["idx"]
                    base = grp["base"]
                    stem = f"{rt_norm}_Path{idx}{_SEP}{base}"
                    
                    if grp["kind"] == "pe":
                        if _as_bool(config.get("DEDUP_PE", True)):
                            outs += [
                                os.path.join(bdir, f"{stem}.markdup.bam"),
                                os.path.join(bdir, f"{stem}.markdup.bam.bai"),
                            ]
                        else:
                            outs += [
                                os.path.join(bdir, f"{stem}.sorted.bam"),
                                os.path.join(bdir, f"{stem}.sorted.bam.bai"),
                            ]
                    else:  # long reads
                        if config.get("DEDUP_LONG", False):
                            outs += [
                                os.path.join(bdir, f"{stem}.markdup.bam"),
                                os.path.join(bdir, f"{stem}.markdup.bam.bai"),
                            ]
                        else:
                            outs += [
                                os.path.join(bdir, f"{stem}.sorted.bam"),
                                os.path.join(bdir, f"{stem}.sorted.bam.bai"),
                            ]
                
                # per sample+readtype merged + QC
                outs += [
                    os.path.join(bdir, f"{sid}.{rt_norm}.merged.bam"),
                    os.path.join(bdir, f"{sid}.{rt_norm}.merged.bam.bai"),
                    os.path.join(bdir, "qc", f"{sid}.{rt_norm}.flagstat.txt"),
                    os.path.join(bdir, "qc", f"{sid}.{rt_norm}.idxstats.tsv"),
                    os.path.join(bdir, "qc", f"{sid}.{rt_norm}.coverage.tsv"),
                    os.path.join(bdir, "qc", f"{sid}.{rt_norm}.summary.txt"),
                    os.path.join(bdir, "qc", f"{sid}.{rt_norm}.summary.md"),
                ]
            
            # Add merge decision for even if single tech samples (OUTSIDE the rt_key loop!)
            outs.append(os.path.join(bdir, "merge_decision.json"))
                
            # Add merged BAM for multi-tech when merge might happen
            if tech_count > 1 and config.get("MERGE_TECH", "auto").lower() != "off":
                outs.append(os.path.join(bdir, f"{sid}.merged.bam"))
                outs.append(os.path.join(bdir, f"{sid}.merged.bam.bai"))
            
        except (KeyError, TypeError, AttributeError):
            continue
        
        # Add aggregate report once per assembly
        if (sp, asm) not in seen:
            seen.add((sp, asm))
            outs.append(os.path.join(
                config["OUT_FOLDER"], "GAME_results", sp, asm, "samples", "bam_qc.md"
            ))

    return outs

# --- Variant calling ---
def get_variant_calling_results():
    """Collect variant calling outputs (raw BCF and gVCF)"""
    outs = []
    if not _as_bool(config.get("RUN_CALLING", True)):
        return outs
    
    for sp, asm, sid in all_samples_iter():
        # Check if sample has reads
        try:
            sample_data = samples_config["sp_name"][sp]["asm_id"][asm]["sample_id"][sid]
            has_reads = False
            for rt_key in sample_data.get("read_type", {}):
                if rt_key not in ["None", None]:
                    _, _, reads = _get_sample_node(sp, asm, sid, rt_key)
                    if reads:
                        has_reads = True
                        break
            if not has_reads:
                continue
        except (KeyError, TypeError, AttributeError):
            continue
        
        vcdir = os.path.join(config["OUT_FOLDER"], "GAME_results", sp, asm, "samples", sid, "VCFs")
        
        # Keep gVCF if configured
        if _as_bool(config.get("KEEP_gVCF", True)):
            outs += [
                os.path.join(vcdir, f"{sid}{_BP_TAG}.g.vcf.gz"),
                os.path.join(vcdir, f"{sid}{_BP_TAG}.g.vcf.gz.tbi"),
            ]

    return outs

# --- Variant filtering / tagging ---
def get_variant_filtering_results():
    """Collect variant tagging outputs"""
    outs = []
    if not _as_bool(config.get("RUN_CALLING", True)):
        return outs

    RUN_TAGGING = _as_bool(config.get("RUN_TAGGING", True))
    KEEP_RAW_BCF = _as_bool(config.get("KEEP_RAW_BCF", False))
    
    for sp, asm, sid in all_samples_iter():
        # Check if sample has reads
        try:
            sample_data = samples_config["sp_name"][sp]["asm_id"][asm]["sample_id"][sid]
            has_reads = False
            for rt_key in sample_data.get("read_type", {}):
                if rt_key not in ["None", None]:
                    _, _, reads = _get_sample_node(sp, asm, sid, rt_key)
                    if reads:
                        has_reads = True
                        break
            if not has_reads:
                continue
        except (KeyError, TypeError, AttributeError):
            continue
        
        vcdir = os.path.join(config["OUT_FOLDER"], "GAME_results", sp, asm, "samples", sid, "VCFs")
        
        if RUN_TAGGING:
            # Full tagging pipeline: both annotate and filter
            outs += [
                os.path.join(vcdir, f"{sid}{_BP_TAG}.tagged.bcf"),
                os.path.join(vcdir, f"{sid}{_BP_TAG}.tagged.bcf.csi"),
                os.path.join(vcdir, f"{sid}.tagging_stats.md"),
            ]
        else:
            # No tagging: raw BCF is final
            outs += [
                os.path.join(vcdir, f"{sid}{_BP_TAG}.raw.bcf"),
                os.path.join(vcdir, f"{sid}{_BP_TAG}.raw.bcf.csi"),
            ]
    
    return outs

# --- Joint genotyping (GLnexus) ---
def get_joint_genotyping_results():
    """Collect joint genotyping outputs (one joint BCF per species/assembly with ≥2 samples)"""
    outs = []
    if not _as_bool(config.get("JOINT_GENO", False)):
        return outs
    
    RUN_TAGGING = _as_bool(config.get("RUN_TAGGING", True))
    
    # Group samples by (species, assembly)
    asm_sample_count = {}
    for sp, asm, sid in all_samples_iter():
        try:
            sample_data = samples_config["sp_name"][sp]["asm_id"][asm]["sample_id"][sid]
            has_reads = False
            for rt_key in sample_data.get("read_type", {}):
                if rt_key not in ["None", None]:
                    _, _, reads = _get_sample_node(sp, asm, sid, rt_key)
                    if reads:
                        has_reads = True
                        break
            if not has_reads:
                continue
        except (KeyError, TypeError, AttributeError):
            continue
        
        key = (sp, asm)
        asm_sample_count[key] = asm_sample_count.get(key, 0) + 1
    
    # Only add joint BCF for assemblies with ≥2 samples
    for (sp, asm), count in asm_sample_count.items():
        if count >= 2:
            jdir = os.path.join(config["OUT_FOLDER"], "GAME_results", sp, asm, "jointVCFs")
            
            if RUN_TAGGING:
                outs += [
                    os.path.join(jdir, f"{asm}.joint.tagged.bcf"),
                    os.path.join(jdir, f"{asm}.joint.tagged.bcf.csi"),
                    os.path.join(jdir, f"{asm}.joint.tagging_stats.md"),
                ]
                # Indented these inside the 'if' block
                rdir = os.path.join(config["OUT_FOLDER"], "GAME_results", sp, asm, "relatedness")
                fdir = os.path.join(config["OUT_FOLDER"], "GAME_results", sp, asm, "finalVCFs")
                outs += [
                    os.path.join(rdir, f"{asm}.relatedness_stats.md"),
                    os.path.join(fdir, f"{asm}.joint.clean.bcf"),
                    os.path.join(fdir, f"{asm}.joint.clean.bcf.csi"),
                    os.path.join(fdir, f"{asm}.joint.clean_stats.md"),
                    os.path.join(fdir, f"{asm}.joint.final.bcf"),
                    os.path.join(fdir, f"{asm}.joint.final.bcf.csi"),
                    os.path.join(fdir, f"{asm}.ld_prune_stats.md"),
                ]
            else:
                outs += [
                    os.path.join(jdir, f"{asm}.joint.bcf"),
                    os.path.join(jdir, f"{asm}.joint.bcf.csi"),
                ]
        else:
            if IS_MAIN: print(f"[GAME] Skipping joint genotyping for {sp}/{asm} (only {count} sample)")
    return outs

# --- ROH analysis ---
def get_roh_results():
    """Collect Roller_Coaster ROH analysis outputs"""
    outs = []
    if not _as_bool(config.get("RUN_ROCO", False)):
        return outs
    
    for sp, asm, sid in all_samples_iter():
        # Check if sample has reads
        try:
            sample_data = samples_config["sp_name"][sp]["asm_id"][asm]["sample_id"][sid]
            has_reads = False
            for rt_key in sample_data.get("read_type", {}):
                if rt_key not in ["None", None]:
                    _, _, reads = _get_sample_node(sp, asm, sid, rt_key)
                    if reads:
                        has_reads = True
                        break
            if not has_reads:
                continue
        except (KeyError, TypeError, AttributeError):
            continue
        
        rohdir = os.path.join(config["OUT_FOLDER"], "GAME_results", sp, asm, "samples", sid, "ROH")
        outs += [
            os.path.join(rohdir, f"{sid}.roh.bed"),
            os.path.join(rohdir, f"{sid}.roh.summary"),
            os.path.join(rohdir, f"{sid}.chrom_thresholds.tsv"),
            os.path.join(rohdir, f"{sid}.windows.tsv.gz"),
            os.path.join(rohdir, f"{sid}.genome_stats.txt"),
            os.path.join(rohdir, f"{sid}.heterozygosity_plots.pdf"),
            os.path.join(rohdir, f"{sid}.froh_proportion.pdf"),
            os.path.join(rohdir, f"{sid}.froh_count.pdf"),
            os.path.join(rohdir, f"{sid}.froh_length.pdf"),
        ]
    
    return outs

# --- PSMC analysis ---
def get_psmc_results():
    """Collect PSMC outputs"""
    outs = []
    if not _as_bool(config.get("RUN_PSMC", False)):
        return outs
    
    for sp, asm, sid in all_samples_iter():
        # Check if sample has reads
        try:
            sample_data = samples_config["sp_name"][sp]["asm_id"][asm]["sample_id"][sid]
            has_reads = False
            for rt_key in sample_data.get("read_type", {}):
                if rt_key not in ["None", None]:
                    _, _, reads = _get_sample_node(sp, asm, sid, rt_key)
                    if reads:
                        has_reads = True
                        break
            if not has_reads:
                continue
        except (KeyError, TypeError, AttributeError):
            continue
        
        smcdir = os.path.join(config["OUT_FOLDER"], "GAME_results", sp, asm, "samples", sid, "SMC")
        
        # Always include validation status and stats
        outs += [
            os.path.join(smcdir, f"{sid}.psmcfa.status"),
            os.path.join(smcdir, f"{sid}.psmcfa.stats.txt"),
        ]
        
        # Always include PSMC outputs (even if empty when validation fails)
        outs += [
            os.path.join(smcdir, f"{sid}.psmc"),
            os.path.join(smcdir, f"{sid}.combined.psmc"),
            os.path.join(smcdir, f"{sid}.psmc_diagnostics.txt"),
        ]
        
        # Always include plot script
        outs.append(os.path.join(smcdir, f"{sid}.plot_psmc.R"))
    
    return outs


# -------------------------------------------------------------------------------
# MAIN OUTPUT FUNCTION
# -------------------------------------------------------------------------------

def get_all_expected_outputs():
    expected_files = []
    
    # Assembly stats (gfastats always runs, compleasm respects RUN_COMPL)
    expected_files.extend(get_asm_stats_results())
    
    # Conditionally add repeat masking results based on data table
    expected_files.extend(get_repeat_masking_results())

    # Always add read processing/QC results (based on control panel choices)
    expected_files.extend(get_read_processing_results())

    # Check if mapping should be run considering data availability
    mapping_on = _as_bool(config.get("READS_MAPPING", True))
    if mapping_on:
        # Add mapping results (mapping + dedup + merge + QC)
        expected_files.extend(get_mapping_results())

        # Variant calling depends on mapping and control panel choices
        expected_files.extend(get_variant_calling_results())
        
        # Tagging depends on variant calling control panel choices
        expected_files.extend(get_variant_filtering_results())
        
        # Joint genotyping (GLnexus, requires CALLER: deep + MERGE_TECH: off)
        expected_files.extend(get_joint_genotyping_results())
        
        # ROH analysis
        expected_files.extend(get_roh_results())

        # PSMC analysis
        expected_files.extend(get_psmc_results())
    else:
        if IS_MAIN: print("[GAME] READS_MAPPING is off - pipeline will run assembly stats and read QC only, and masking if enabled.")
    return expected_files


