# TEMP_DIR options:
#   "default" or "" -> OUT_FOLDER/GAME_results/tmp
#   "auto" -> detect from profile's apptainer-args, check space at runtime, fall back
#   "{path}" -> use that path
#
# FAST_TEMP_DIR options:
#   "default" or "" -> same as TEMP_DIR (shows hints for faster options)
#   "{path}" -> use that path

# --- Discovery functions ---
def _detect_ramfs_mounts():
    """Detect RAM-mounted filesystems"""
    mounts = []
    try:
        with open("/proc/mounts") as f:
            for line in f:
                parts = line.split()
                if len(parts) >= 3:
                    dev, mnt, fstype = parts[0], parts[1], parts[2]
                    if fstype in ("tmpfs", "ramfs", "hugetlbfs"):
                        try:
                            st = os.statvfs(mnt)
                            free_gb = st.f_bavail * st.f_frsize / (1024**3)
                        except:
                            free_gb = None
                        mounts.append((mnt, fstype, free_gb))
    except:
        pass
    return mounts

def _parse_fast_paths_from_profiles():
    """
    Parse apptainer-args from execution profiles to find fast temp paths.
    Returns a list of paths in priority order (localscratch > local > home).
    Appends /tmp to each path for organization.
    """
    profile_paths = [
        ROOT / "execution" / "slurm" / "config.yaml",
        ROOT / "execution" / "local" / "config.yaml",
    ]
    
    # Priority order: localscratch first, then local, then home
    fast_keywords_priority = [
        ("/localscratch", 1),
        ("/local/", 2),
        ("/home", 3),
    ]
    
    found_paths = []  # List of (priority, path)
    
    for profile_path in profile_paths:
        if not profile_path.exists():
            continue
        try:
            with open(profile_path) as f:
                profile_config = yaml.safe_load(f) or {}
            
            # Look for apptainer-args or singularity-args
            apptainer_args = profile_config.get("apptainer-args", "") or profile_config.get("singularity-args", "")
            
            if not apptainer_args:
                continue
            
            # Parse --bind arguments: --bind /path:/path or --bind /path
            bind_matches = re.findall(r'--bind\s+([^\s]+)', apptainer_args)
            
            for bind_arg in bind_matches:
                # Handle both /path:/path and /path formats
                source_path = bind_arg.split(":")[0]
                
                # Check if this path matches our fast keywords
                for keyword, priority in fast_keywords_priority:
                    if keyword in source_path:
                        # Add /tmp subdirectory for organization
                        tmp_path = os.path.join(source_path, "tmp")
                        # Avoid duplicates
                        if tmp_path not in [p[1] for p in found_paths]:
                            found_paths.append((priority, tmp_path))
                            if IS_MAIN: print(f"[GAME] Found fast temp candidate from profile: {tmp_path} (priority {priority})")
                        break
                        
        except Exception as e:
            print(f"[GAME] Warning: Could not parse {profile_path}: {e}")
            continue
    
    # Sort by priority and return just the paths
    found_paths.sort(key=lambda x: x[0])
    return [p[1] for p in found_paths]

# Default fallback is always available
FALLBACK_TMP = os.path.join(config["OUT_FOLDER"], "GAME_results", "tmp")
os.makedirs(FALLBACK_TMP, exist_ok=True)

# --- Parse TEMP_DIR config ---
