# -------------------------------------------------------------------------------
# MAIN-PROCESS DETECTION
# -------------------------------------------------------------------------------
# Guards top-level prints (banners, logs) against re-execution in worker processes.
# IS_MAIN is True only in the parent process; workers skip noisy prints.
#
# note: Running Snakemake via srun/sbatch may suppress the banner (the pipeline
# still runs fine). To keep it, drop the SLURM_JOB_ID check below.

def is_main_process():
    """Return True if this is the main Snakemake process, not a worker."""
    # Cluster workers — SLURM injects SLURM_JOB_ID into every job;
    # Snakemake also sets its own job IDs in the worker environment.
    is_cluster_worker = any([
        os.environ.get("SNAKEMAKE_JOBID"),
        os.environ.get("SNAKEMAKE_SLURM_JOBID"),
        os.environ.get("SLURM_JOB_ID"),
    ])
    # Local workers — Snakemake re-invokes itself with `--mode subprocess`.
    is_local_worker = False
    for i, arg in enumerate(sys.argv):
        if arg == "--mode" and i + 1 < len(sys.argv) and sys.argv[i + 1] == "subprocess":
            is_local_worker = True
            break
    return not (is_cluster_worker or is_local_worker)


IS_MAIN = is_main_process()


